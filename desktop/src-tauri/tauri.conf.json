{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Job Application Tracker",
  "version": "1.0.0",
  "identifier": "com.gh4zii.jobapplicationtracker",
  "build": {
    "beforeDevCommand": "npm run build --prefix ../frontend && npm run dev --prefix ../backend",
    "devUrl": "http://127.0.0.1:3001",
    "beforeBuildCommand": "npm run build --prefix ..",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Job Application Tracker",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "url": "http://127.0.0.1:3001"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/job-tracker-api"]
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
