{
  "name": "job-application-tracker-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:sidecar": "npm run build && npm run copy:frontend && npm run pkg:win && node scripts/copy-sidecar-assets.mjs",
    "copy:sidecar-assets": "node scripts/copy-sidecar-assets.mjs",
    "copy:frontend": "node scripts/copy-frontend.mjs",
    "pkg:win": "pkg dist/server.js --targets node20-win-x64 --output ../desktop/src-tauri/binaries/job-tracker-api-x86_64-pc-windows-msvc.exe",
    "start": "node dist/server.js",
    "desktop:build": "npm run desktop:build --prefix ..",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.8.2",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4",
    "@yao-pkg/pkg": "^6.3.2"
  },
  "pkg": {
    "assets": [
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/engines/**/*",
      "prisma/**/*",
      "frontend/dist/**/*"
    ],
    "outputPath": "../desktop/src-tauri/binaries"
  }
}
